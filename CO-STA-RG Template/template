<PromptTemplate>
    <!-- ═════════════════════════════════════════════════════════════════════ -->
    <!-- 1. METADATA - ข้อมูลประจำตัว Prompt -->
    <!-- ═════════════════════════════════════════════════════════════════════ -->
    <Metadata>
        <Title>[ชื่อ Prompt ที่ชัดเจนสั้นๆ]</Title>
        <Creator>[ชื่อผู้สร้าง]</Creator>
        <Version>[เวอร์ชัน เช่น 1.0]</Version>
        <CreatedDate>[วันที่สร้าง YYYY-MM-DD]</CreatedDate>
        <LastModified>[วันที่แก้ไขล่าสุด YYYY-MM-DD]</LastModified>
        <Tags>[คำค้นหา, แยกด้วย comma]</Tags>
        <Category>[เช่น: Analysis, Generation, Transformation, Decision-Making]</Category>
        <Complexity>[Basic / Intermediate / Advanced]</Complexity>
    </Metadata>

    <!-- ═════════════════════════════════════════════════════════════════════ -->
    <!-- 2. CONTEXT (C) - บริบท ฉากหลัง สถานการณ์ -->
    <!-- ═════════════════════════════════════════════════════════════════════ -->
    <Context>
        <!-- 2.1 สถานการณ์ที่ต้องการแก้ไข -->
        <Situation>
            <Problem>
                [ปัญหาที่เกิดขึ้น หรือสถานการณ์ที่ต้องจัดการ]
                [เช่น: "การเขียน XML Prompt ยังไม่มีโครงสร้างแบบ universal"]
            </Problem>
            <Background>
                [ข้อมูลเบื้องหลัง ประวัติศาสตร์ หรือบริบท]
                [เช่น: "GKT-thai มีความต้องการ standardized prompt framework"]
            </Background>
        </Situation>

        <!-- 2.2 ผู้เกี่ยวข้อง (Stakeholders) -->
        <Stakeholders>
            <Audience>[ผู้ใช้ Prompt นี้ เช่น: GKT-thai Team, Prompt Engineers]</Audience>
            <ExpertiseLevel>[Beginner / Intermediate / Expert]</ExpertiseLevel>
            <KnowledgeAssumptions>
                [สิ่งที่ถือว่ารู้แล้ว เช่น: "รู้พื้นฐาน XML, ความรู้เกี่ยวกับ BDL"]
            </KnowledgeAssumptions>
        </Stakeholders>

        <!-- 2.3 ข้อจำกัด (Constraints) ของบริบท -->
        <EnvironmentalConstraints>
            <Item>
                [ข้อจำกัดเวลา/ทรัพยากร/เทคนิค เช่น: "ต้องทำให้สำเร็จใน 30 นาที"]
            </Item>
            <Item>
                [เช่น: "ใช้ได้เฉพาะกับ Claude API"]
            </Item>
        </EnvironmentalConstraints>

        <!-- 2.4 บริบทสถาบัน (Organizational Context) -->
        <OrganizationalContext>
            <Mission>[เป้าหมายองค์กร หากเกี่ยวข้อง]</Mission>
            <Standards>[มาตรฐานที่ต้องปฏิบัติตาม เช่น: "GKT-thai Standards v2.0"]</Standards>
            <RelatedFrameworks>[Framework ที่เกี่ยวข้อง เช่น: "BDL Apex Prime, GTK-SYS-18.0"]</RelatedFrameworks>
        </OrganizationalContext>
    </Context>

    <!-- ═════════════════════════════════════════════════════════════════════ -->
    <!-- 3. OBJECTIVE (O) - เป้าหมาย สิ่งที่ต้องการให้ AI ทำ -->
    <!-- ═════════════════════════════════════════════════════════════════════ -->
    <Objective>
        <!-- 3.1 เป้าหมายหลัก (Primary Goal) -->
        <PrimaryGoal>
            [เป้าหมายสุดท้ายที่ชัดเจนที่สุด]
            [เช่น: "สร้างคู่มือใช้งาน CO-STA-RG ที่สามารถนำไปปฏิบัติได้"]
        </PrimaryGoal>

        <!-- 3.2 เป้าหมายย่อย (Sub-goals) -->
        <SubGoals>
            <Goal sequence="1">
                [เช่น: "วิเคราะห์ความหมายของแต่ละตัวอักษร (C-O-S-T-A-R-G)"]
            </Goal>
            <Goal sequence="2">
                [เช่น: "ระบุวิธีนำแต่ละส่วนไปประยุกต์ใช้ในการเขียน Prompt"]
            </Goal>
            <Goal sequence="3">
                [เช่น: "สร้างตัวอย่าง (Example) ที่ใช้ได้จริง"]
            </Goal>
        </SubGoals>

        <!-- 3.3 ผลลัพธ์ที่คาดหวัง (Expected Outputs) -->
        <ExpectedOutputs>
            <Output type="primary">
                [ประเภท: บทความ, โค้ด, รายงาน, คู่มือ, ฯลฯ]
                [รูปแบบ: Markdown, XML, JSON, ฯลฯ]
                [เช่น: "Markdown document พร้อมตัวอย่าง XML"]
            </Output>
            <Output type="secondary">
                [เช่น: "ตัวอย่าง Prompt อยู่ 2-3 ตัวอย่าง"]
            </Output>
        </ExpectedOutputs>

        <!-- 3.4 Success Criteria (เกณฑ์ความสำเร็จ) -->
        <SuccessCriteria>
            <Criterion priority="critical">
                [เกณฑ์สำคัญที่สุด เช่น: "ต้องถูกต้อง 100% ตามไฟล์ต้นทาง"]
            </Criterion>
            <Criterion priority="high">
                [เช่น: "ใช้ภาษาไทยกระชับแต่เข้าใจง่าย"]
            </Criterion>
            <Criterion priority="medium">
                [เช่น: "มีตัวอย่าง XML Code Block"]
            </Criterion>
        </SuccessCriteria>
    </Objective>

    <!-- ═════════════════════════════════════════════════════════════════════ -->
    <!-- 4. STATE (S) - สถานะปัจจุบัน ข้อมูลนำเข้า Input -->
    <!-- ═════════════════════════════════════════════════════════════════════ -->
    <State>
        <!-- 4.1 ข้อมูลนำเข้า (Input Data) -->
        <InputData>
            <DataSource type="primary">
                [ที่มาของข้อมูล เช่น: "GitHub Repository: imron-Gkt/CO-STA-RG"]
                [รูปแบบ: URL / Raw Content / File Upload / Direct Text]
            </DataSource>
            <DataSource type="secondary">
                [เช่น: "BDL Apex Prime Documentation"]
            </DataSource>
            <DataFormat>[เช่น: "Markdown, JSON, XML"]</DataFormat>
            <DataVolume>[ขนาด เช่น: "< 50KB"]</DataVolume>
            </InputData>

            <!-- 4.2 สถานะปัจจุบัน (Current State / Known Information) -->
            <CurrentKnowledge>
                <KnownFact>
                    [ข้อเท็จจริงที่รู้แล้ว เช่น: "CO-STA-RG คือ prompt framework"]
                </KnownFact>
                <KnownFact>
                    [เช่น: "ต้องเป็นไปตาม GKT-thai standards"]
                </KnownFact>
            </CurrentKnowledge>

            <!-- 4.3 ความไม่แน่นอน (Uncertainties / Gaps) -->
            <UnknownFactors>
                <Unknown severity="high">
                    [สิ่งที่ยังไม่ชัดเจน เช่น: "ความหมายที่ชัดเจนของแต่ละตัวอักษร"]
                </Unknown>
                <Unknown severity="medium">
                    [เช่น: "ความต่างจาก CO-STAR-G"]
                </Unknown>
            </UnknownFactors>

            <!-- 4.4 ข้อสมมติ (Assumptions) -->
            <Assumptions>
                <Assumption confidence="high">
                    [สิ่งที่สมมติว่าเป็นจริง เช่น: "ผู้ใช้เข้าใจ XML พื้นฐาน"]
                </Assumption>
                <Assumption confidence="medium">
                    [เช่น: "มีความรู้พื้นฐาน prompt engineering"]
                </Assumption>
            </Assumptions>
        </State>

        <!-- ═════════════════════════════════════════════════════════════════════ -->
        <!-- 5. TASK (T) - งานที่ AI ต้องทำ กระบวนการ -->
        <!-- ═════════════════════════════════════════════════════════════════════ -->
        <Task>
            <!-- 5.1 ขั้นตอนหลัก (Main Process Steps) -->
            <ProcessSteps>
                <Step sequence="1" name="[ชื่อขั้นตอน]">
                    <Description>
                        [คำอธิบายรายละเอียด สิ่งที่ต้องทำในขั้นตอนนี้]
                    </Description>
                    <InputRequired>
                        [ข้อมูลหรืออินพุตที่ต้องใช้ในขั้นตอนนี้]
                    </InputRequired>
                    <OutputExpected>
                        [ผลลัพธ์ที่คาดหวังจากขั้นตอนนี้]
                    </OutputExpected>
                    <TimeEstimate>[เวลาประมาณ เช่น: "5 นาที"]</TimeEstimate>
                </Step>

                <Step sequence="2" name="[ชื่อขั้นตอน]">
                    <!-- เหมือนด้านบน -->
                </Step>

                <Step sequence="3" name="[ชื่อขั้นตอน]">
                    <!-- เหมือนด้านบน -->
                </Step>
            </ProcessSteps>

            <!-- 5.2 วิธีการทำงาน (Methodology) -->
            <Methodology>
                <Approach>[วิธีการที่ใช้ เช่น: "Structural Analysis"]</Approach>
                <Framework>[Framework ที่อ้างอิง เช่น: "BDL Apex Prime"]</Framework>
                <Tools>[เครื่องมือที่ใช้ เช่น: "Markdown, XML"]</Tools>
            </Methodology>

            <!-- 5.3 เงื่อนไขและการตัดสินใจ (Decision Points) -->
            <DecisionPoints>
                <Decision condition="[เงื่อนไข]">
                    <IfTrue>[ถ้าเป็นจริง ให้ทำ...]</IfTrue>
                    <IfFalse>[ถ้าเป็นเท็จ ให้ทำ...]</IfFalse>
                </Decision>
            </DecisionPoints>

            <!-- 5.4 Quality Checks (ตรวจสอบคุณภาพ) -->
            <QualityCheckpoints>
                <Checkpoint sequence="1">
                    [เช่น: "ตรวจสอบความถูกต้องของข้อมูลจากต้นทาง"]
                </Checkpoint>
                <Checkpoint sequence="2">
                    [เช่น: "ตรวจสอบภาษาไทยและเทคนิก"]
                </Checkpoint>
            </QualityCheckpoints>
        </Task>

        <!-- ═════════════════════════════════════════════════════════════════════ -->
        <!-- 6. ACTION (A) - การดำเนินการ สิ่งที่ AI ต้องสร้าง/ออกมา -->
        <!-- ═════════════════════════════════════════════════════════════════════ -->
        <Action>
            <!-- 6.1 การดำเนินการหลัก (Primary Actions) -->
            <PrimaryActions>
                <Action type="analysis">
                    [เช่น: "วิเคราะห์โครงสร้าง CO-STA-RG จาก input"]
                </Action>
                <Action type="synthesis">
                    [เช่น: "รวมข้อมูลเป็นคู่มือเป็นขั้นเป็นตอน"]
                </Action>
                <Action type="creation">
                    [เช่น: "สร้างตัวอย่าง XML Prompt"]
                </Action>
            </PrimaryActions>

            <!-- 6.2 Output Specifications (การระบุรายละเอียดผลลัพธ์) -->
            <OutputSpecifications>
                <Format>[รูปแบบ เช่น: "Markdown with Code Blocks"]</Format>
                <Structure>
                    [โครงสร้าง เช่น: "# Heading, ## Subheading, - Bullet, ```xml```"]
                </Structure>
                <Language>[ภาษา เช่น: "ไทย (อังกฤษสำหรับเทคนิค)"]</Language>
                <Length>[ความยาว เช่น: "1000-1500 words"]</Length>
                <Tone>[ลีลา เช่น: "Professional, Clear, Actionable"]</Tone>
                <Examples>[จำนวนตัวอย่าง เช่น: "3-5 examples"]</Examples>
            </OutputSpecifications>

            <!-- 6.3 Transformation Rules (กฎการแปลง/จัดการข้อมูล) -->
            <TransformationRules>
                <Rule priority="critical">
                    [เช่น: "ต้องอ้างอิงจากไฟล์ต้นทางเท่านั้น ห้ามคาดเดา"]
                </Rule>
                <Rule priority="high">
                    [เช่น: "ใช้ตัวอักษรพิมพ์ใหญ่สำหรับ CO-STA-RG"]
                </Rule>
                <Rule priority="high">
                    [เช่น: "เชื่อมโยงแต่ละส่วนกับ BDL Apex Prime"]
                </Rule>
            </TransformationRules>

            <!-- 6.4 Fallback / Error Handling -->
            <ErrorHandling>
                <Error condition="[เช่น: GitHub URL ไม่สามารถเข้าถึง]">
                    <Action>[เช่น: "ขอ Raw Content จากผู้ใช้"]</Action>
                </Error>
                <Error condition="[เช่น: ข้อมูลไม่สมบูรณ์]">
                    <Action>[เช่น: "ถามผู้ใช้ให้ชี้แจงเพิ่มเติม"]</Action>
                </Error>
            </ErrorHandling>
        </Action>

